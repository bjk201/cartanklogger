# .env.example – Erforderliche Umgebungsvariablen für den Betrieb von Docker Compose
# Kopieren Sie diese Datei nach .env und füllen Sie die Geheimnisse aus (oder exportieren Sie diese als Variablen).

# ----- EVCC (zuhause) Konfiguration -----
EVCC_HOST=evcc.local           # hostname oder LAN-IP des EVCC Docker-Containers
EVCC_PORT=7070                 # Standard-Port
EVCC_USE_TLS=false             # true, wenn EVCC mit TLS läuft (standardmäßig falsch)
EVCC_PASSWORD=                # Wenn EVCC das Passwortverschlüsselungsverfahren für die API verwendet. Leerlassend, wenn EVCC API_TOKEN verwendet.
EVCC_API_TOKEN=               # Wenn EVCC die API-Authentifizierung mit einem Token verwendet.

# ----- TeslaMate (Ladeprotokoll) Konfiguration -----
TESLAMATE_URL=http://teslamate:4000/api  # https://{TS_IP}:4000/api, falls Sie den TeslaMate Docker-Container verwenden
TESLAMATE_API_TOKEN=              # TeslaMate API-Token zum Abrufen der Ladungen

# ----- Cartanklogger interne Konfiguration -----
CONFIG_PATH=/app/config.yaml    # Pfad zur Cartanklogger YAML-Konfiguration innerhalb des Containers (gleich wie CMD)
DB_PATH=/app/data/cartanklogger.db# Verzeichnis innerhalb des Containers, in dem die SQLite-Datenbank gespeichert wird
MOCK_MODE=false                  # false -> echte Anfragen; true → nutzen Sie das eingebaute Testdatenmodell (idealerweise für E2E-Tests)

# ----- Optionalere für die Zeitmessung, Debugging -----
FLASK_ENV=production             # Setze auf "development", wenn Sie das Flask-Debug-Modus benötigen
TZ=Europe/Berlin                # Zeitzonenzuordnung für die historiebasierte Berechnung

# ----- Verschlüsselungsgeheimnis (optional) -----
SECRET_KEY=                     # Wenn nicht gesetzt: Herleitung basierend auf der DB-Pfad-Hash (db.py)

# ----- E2E-Test spezifisch (falls MOCK_MODE=true) -----
# Speichern Sie alle Testautomatisierungs-ähnliche Variablen hier - optional

# ----- Hinweise zur Laufzeit / Container-Ausführung -----
# Daten werden unter /app/data gespeichert (Bind-Mount host:"./data") – niemals löschen, wenn Sie den Image beibehalten möchten.
# Alle schreibenden Operationen (Editoren, Admin-Tools) sind zusätzlich CSRF-geschützt.
# Für die ersten Starts von MOCK_MODE verwenden Sie den Seed-Endpunkt, um den historischen Daten der SQLite-Datenbank für den gesamten Zeitraum zu initialisieren.
# Verbessern Sie .env.* um Ihre tatsächlichen Werte – die Datei wird nicht versioniert (es sei denn, Sie fügen Secrets hinzu).
